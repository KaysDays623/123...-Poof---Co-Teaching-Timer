{
  "manifest_version": 3,
  "name": "123... Poof - Co Teaching Timer",
  "version": "1.0",
  "description": "A shared classroom timer overlay for virtual co-teachers.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.firebaseio.com/*",
    "https://*.firebasedatabase.app/*"
  ],
  "action": {
    "default_title": "123... Poof - Co Teaching Timer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}